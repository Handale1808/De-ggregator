{
  "manifest_version": 3,
  "name": "De-aggregator",
  "version": "1.0.0",
  "description": "Find the original source of aggregated news articles",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
  "https://google.serper.dev/*"
]
}
